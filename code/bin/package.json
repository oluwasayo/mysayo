{
  "description": "Deployment and utility scripts",
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  },
  "name": "bin",
  "private": true,
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf dist && find src -type f -name \"*.js\" -delete 2>/dev/null || true",
    "filter-terraform-plan": "tsx src/filter-terraform-plan.ts",
    "fix": "npm run clean && tsc && npm run lint:fix",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "tsc": "tsc"
  },
  "type": "module",
  "version": "0.0.1"
}
