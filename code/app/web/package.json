{
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 ChromeAndroid versions",
    "last 2 Edge versions",
    "last 2 Firefox versions",
    "Firefox ESR",
    "last 2 Safari major versions",
    "last 2 iOS major versions",
    "not OperaMini all"
  ],
  "dependencies": {
    "@astrojs/react": "6.0.0",
    "astro": "7.0.2",
    "react": "19.2.7",
    "react-compiler-runtime": "1.0.0",
    "react-dom": "19.2.7"
  },
  "description": "Personal website",
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.9",
    "babel-plugin-react-compiler": "1.0.0",
    "playwright": "1.61.0",
    "stylelint": "17.13.0",
    "stylelint-config-css-modules": "4.6.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-no-unsupported-browser-features": "8.1.1",
    "stylelint-order": "8.1.1",
    "typescript": "7.0.1-rc",
    "vite": "8.1.0",
    "vitest": "4.1.9",
    "wrangler": "4.104.0"
  },
  "name": "web",
  "private": true,
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "clean": "find src -type f -name \"*.js\" -delete 2>/dev/null || true && rm -rf dist .astro coverage",
    "deploy": "npm run build && wrangler pages deploy",
    "dev:web": "astro dev",
    "fix": "npm run clean && npm run tsc && npm run lint:fix",
    "install:testing:deps": "npx playwright install chromium --with-deps",
    "lint": "biome check . && npm run -s stylelint",
    "lint:fix": "biome check . --write && npm run -s stylelint:fix",
    "preview": "astro preview",
    "stylelint": "stylelint \"src/**/*.css\"",
    "stylelint:fix": "stylelint \"src/**/*.css\" --fix",
    "test": "vitest run",
    "test:ci": "vitest run --silent --reporter=junit --outputFile=./test-results/junit.xml",
    "test:coverage": "vitest run --coverage",
    "tsc": "astro sync && tsc"
  },
  "type": "module",
  "version": "0.0.1"
}
