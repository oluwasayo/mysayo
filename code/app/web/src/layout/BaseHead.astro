---
import {
  siteAuthor,
  siteDescription,
  siteName,
  siteUrl,
  siteXHandle,
  socialLinks,
} from '@shared/lib/site'
import '@/style/global.css'

type Props = {
  title: string
  description?: string
  ogType?: 'website' | 'article'
  publishedTime?: string
  modifiedTime?: string
  headline?: string
  styles?: string[]
}

const {
  title,
  description = siteDescription,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  headline,
  styles = [],
} = Astro.props
const canonical = new URL(Astro.url.pathname, siteUrl).href
const rssUrl = new URL('/rss.xml', siteUrl).href

const ogRoute = Astro.url.pathname.replace(/^\/+|\/+$/g, '') || 'index'
const ogImage = new URL(`/og/${ogRoute}.png`, siteUrl).href

const personId = `${siteUrl}/#person`
const websiteId = `${siteUrl}/#website`
const jsonLdGraph: Record<string, unknown>[] = [
  {
    '@type': 'Person',
    '@id': personId,
    name: siteAuthor,
    url: siteUrl,
    sameAs: socialLinks.map(link => link.href),
  },
  {
    '@type': 'WebSite',
    '@id': websiteId,
    url: siteUrl,
    name: siteName,
    description: siteDescription,
    inLanguage: 'en',
    publisher: { '@id': personId },
  },
]

if (ogType === 'article' && publishedTime) {
  jsonLdGraph.push({
    '@type': 'BlogPosting',
    '@id': `${canonical}#article`,
    headline: headline ?? title,
    description,
    datePublished: publishedTime,
    dateModified: modifiedTime ?? publishedTime,
    inLanguage: 'en',
    image: ogImage,
    author: { '@id': personId },
    publisher: { '@id': personId },
    isPartOf: { '@id': websiteId },
    mainEntityOfPage: canonical,
    url: canonical,
  })
}

const jsonLd = { '@context': 'https://schema.org', '@graph': jsonLdGraph }
// Escape `<` so a value containing `</script>` cannot break out of the JSON-LD tag.
const jsonLdScript = JSON.stringify(jsonLd).replace(/</g, '\\u003c')
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
  rel="stylesheet"
/>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="canonical" href={canonical} />
<link rel="alternate" type="application/rss+xml" title={siteName} href={rssUrl} />

<title>{title}</title>
<meta name="description" content={description} />

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={description} />
{
  ogType === 'article' && publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )
}
{
  ogType === 'article' && modifiedTime && (
    <meta property="article:modified_time" content={modifiedTime} />
  )
}
{
  ogType === 'article' && (
    <meta property="article:author" content={siteAuthor} />
  )
}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={`@${siteXHandle}`} />
<meta name="twitter:creator" content={`@${siteXHandle}`} />
<meta name="twitter:image" content={ogImage} />

<script type="application/ld+json" set:html={jsonLdScript} />

{styles.map(href => <link rel="stylesheet" href={href} />)}

<script is:inline>
  ;(() => {
    let stored = null
    try {
      stored = localStorage.getItem('theme')
    } catch {
      stored = null
    }
    const preference =
      stored === 'light' || stored === 'dark' || stored === 'system'
        ? stored
        : 'system'
    document.documentElement.dataset.theme = preference
  })()
</script>
