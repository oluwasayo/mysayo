---
import BaseHead from '@/layout/BaseHead.astro'
import SiteFooter from '@/layout/SiteFooter.astro'
import SiteHeader from '@/layout/SiteHeader.astro'
import { siteName, siteTagline } from '@shared/lib/site'

type Props = {
  title?: string
  description?: string
  ogType?: 'website' | 'article'
  publishedTime?: string
  modifiedTime?: string
  styles?: string[]
}

const { title, description, ogType, publishedTime, modifiedTime, styles } =
  Astro.props
const pageTitle = title ? `${title} · ${siteName}` : `${siteName} · ${siteTagline}`
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={pageTitle}
      headline={title}
      description={description}
      ogType={ogType}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      styles={styles}
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <SiteHeader />
    <main id="main" class="page" tabindex="-1">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
