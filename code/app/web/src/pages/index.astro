---
import PostList from '@/component/PostList.astro'
import Layout from '@/layout/Layout.astro'
import { getPublishedPosts } from '@/lib/post'
import { siteAuthor } from '@shared/lib/site'

const posts = (await getPublishedPosts()).slice(0, 3)
---

<Layout>
  <div class="wrap">
    <section class="hero">
      <p class="eyebrow">{siteAuthor}</p>
      <h1>Software engineer building products, systems, and cloud infrastructure.</h1>
      <p class="lead hero__lead">
        I design and ship software end to end — product frontends, distributed
        backends, and the infrastructure that runs them. Here, I write about the
        craft behind that work.
      </p>
      <p class="hero__cta">
        <a class="text-link" href="/about">About me →</a>
        <a class="text-link" href="/work">Selected work →</a>
      </p>
    </section>

    {
      posts.length > 0 && (
        <section class="home-section">
          <div class="home-section__head">
            <h2>Recent writing</h2>
            <a class="text-link" href="/writing">
              All writing →
            </a>
          </div>
          <PostList posts={posts} />
        </section>
      )
    }
  </div>
</Layout>
