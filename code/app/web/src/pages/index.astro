---
import PostList from '@/component/PostList.astro'
import Layout from '@/layout/Layout.astro'
import { getPublishedPosts } from '@/lib/posts'
import { siteAuthor } from '@shared/lib/site'

const posts = (await getPublishedPosts()).slice(0, 5)
---

<Layout>
  <div class="wrap">
    <section class="hero">
      <p class="eyebrow">{siteAuthor}</p>
      <h1>Software engineer building for the web and the cloud.</h1>
      <p class="lead hero__lead">
        I design and ship products end to end — typed front-ends, static sites,
        and the infrastructure that runs them. This is where I write about the
        work and how it's built.
      </p>
    </section>

    {
      posts.length > 0 && (
        <section class="home-section">
          <div class="home-section__head">
            <h2>Recent writing</h2>
            <a class="text-link" href="/blog">
              All writing →
            </a>
          </div>
          <PostList posts={posts} />
        </section>
      )
    }
  </div>
</Layout>
