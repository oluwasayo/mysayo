---
import PostList from '@/component/PostList.astro'
import Layout from '@/layout/Layout.astro'
import { getFeaturedPosts } from '@/lib/post'
import { siteAuthor } from '@shared/lib/site'

const posts = await getFeaturedPosts()
---

<Layout>
  <div class="wrap">
    <section class="hero">
      <p class="eyebrow">{siteAuthor}</p>
      <h1>Hands-on engineer, building and leading across product and infrastructure.</h1>
      <p class="lead hero__lead">
        I design, ship, and lead software end to end — product surfaces,
        distributed backends, and the cloud infrastructure that runs them. Here, I write about
        the craft behind that work.
      </p>
      <p class="hero__cta">
        <a class="text-link" href="/about">About me →</a>
        <a class="text-link" href="/work">Selected work →</a>
      </p>
    </section>

    {
      posts.length > 0 && (
        <section class="home-section">
          <div class="home-section__head">
            <h2>Featured writing</h2>
            <a class="text-link" href="/writing">
              All writing →
            </a>
          </div>
          <PostList posts={posts} />
        </section>
      )
    }
  </div>
</Layout>
