---
import Layout from '@/layout/Layout.astro'
---

<Layout title="Page not found" description="That page could not be found.">
  <div class="wrap wrap-text">
    <p class="eyebrow">404</p>
    <h1>Page not found</h1>
    <p class="lead">
      The page you’re looking for moved or never existed. Try the writing index,
      or head back home.
    </p>
    <p>
      <a class="site-nav__link" href="/blog">Writing</a>
    </p>
    <a class="back-link" href="/">← Back home</a>
  </div>
</Layout>
