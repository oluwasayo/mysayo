---
import { Image } from 'astro:assets'
import portrait from '@/asset/sayo.jpg'
import Layout from '@/layout/Layout.astro'
import { profileLinks, siteAuthor } from '@shared/lib/site'

const stack = [
  {
    label: 'Primary',
    value:
      'TypeScript, React, Node.js, GraphQL, AWS, Terraform, PostgreSQL, GitHub Actions',
  },
  { label: 'Others', value: 'Kotlin, Java, Java EE, REST, MySQL, GCP' },
  {
    label: 'Focus',
    value: 'Agent orchestration, AI-native development, evals, observability, developer tools',
  },
]
---

<Layout
  title="About"
  description="Sayo Oladeji — software engineer building products, systems, and AI-native infrastructure."
>
  <div class="wrap">
    <section class="hero about-hero">
      <div class="about-hero__text">
        <p class="eyebrow">About</p>
        <h1>Software engineer building products, systems, and AI-native infrastructure.</h1>
        <p class="lead">
          I started programming long before it became my work, and have built
          software professionally since 2012 — across product, infrastructure,
          media, developer tools, and agent systems.
        </p>
      </div>
      <Image
        class="about-portrait"
        src={portrait}
        alt={siteAuthor}
        widths={[256, 384, 512]}
        sizes="(min-width: 48rem) 16rem, 55vw"
        loading="eager"
      />
    </section>

    <div class="about-prose wrap-text">
      <p>
        My path runs through competitive programming as a student, a Google
        internship, creative infrastructure at Smartly and Meta, low-latency
        audio at Speechify, and engineering effectiveness products at Swarmia.
        Along the way I co-founded and ran engineering for Tellerpoint, a
        fintech platform that moved money at national scale.
      </p>
      <p>
        These days I build production agent systems: task orchestration
        frameworks, multi-phase LLM agents, human-in-the-loop tooling, and the
        product surfaces around them. I also work AI-natively, using Cursor and
        Codex for planning, implementation, debugging, and repeatable automation
        across my toolchain.
      </p>
      <p>
        I've spoken at JavaOne in San Francisco on deploying end-to-end Kotlin
        inside a Java enterprise.
      </p>
    </div>

    <section class="home-section">
      <div class="home-section__head">
        <h2>Currently</h2>
      </div>
      <p class="about-prose">
        CTO at Kreia, building autonomous marketing infrastructure for
        real estate and construction. The work spans customer-signal ingestion,
        real-time prioritization, multi-phase agents, media generation, and the
        production platform that holds it together.
      </p>
    </section>

    <section class="home-section">
      <div class="home-section__head">
        <h2>How I work</h2>
      </div>
      <p class="about-prose">
        I like calm, direct ownership: understand the product, design the system,
        write the code, operate it in production, and keep tightening the loop.
        I enjoy small senior teams where technical judgment, taste, and
        execution all matter. And I place a high value on velocity, readability
        and testability.
      </p>
    </section>

    <section class="home-section">
      <div class="home-section__head">
        <h2>Stack</h2>
      </div>
      <dl class="about-stack">
        {
          stack.map(item => (
            <div class="about-stack__row">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <section class="home-section">
      <div class="home-section__head">
        <h2>Work authorization</h2>
      </div>
      <p class="about-prose muted">
        Full work authorization in the US and EU.
      </p>
    </section>

    <section class="home-section">
      <div class="home-section__head">
        <h2>Elsewhere</h2>
      </div>
      <ul class="about-links">
        {
          profileLinks.map(link => (
            <li>
              <a
                class:list={[link.external && 'external-link']}
                href={link.href}
                rel={link.external ? 'noopener noreferrer' : undefined}
                target={link.external ? '_blank' : undefined}
              >
                {link.label}
                {link.external && (
                  <span class="visually-hidden"> (opens in new tab)</span>
                )}
              </a>
            </li>
          ))
        }
      </ul>
      <p class="about-cta">
        <a class="text-link" href="/work">See selected work →</a>
        <a class="text-link" href="/writing">Read my writing →</a>
      </p>
    </section>
  </div>
</Layout>
