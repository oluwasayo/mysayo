---
import PostList from '@/component/PostList.astro'
import Layout from '@/layout/Layout.astro'
import { getPublishedPosts } from '@/lib/post'

const posts = await getPublishedPosts()
---

<Layout
  title="Writing"
  description="Notes on software engineering, systems, and the making of this site."
>
  <div class="wrap">
    <header class="hero">
      <p class="eyebrow">Writing</p>
      <h1>Notes on building software.</h1>
      <p class="lead hero__lead">
        Essays and field notes on software engineering, systems, and the making
        of this site.
      </p>
    </header>

    <div class="home-section">
      <PostList posts={posts} />
    </div>
  </div>
</Layout>
