---
import { getTagLabel, type Tag } from '@/lib/tag'

type Props = {
  tags: Tag[]
}

const { tags } = Astro.props
---

{
  tags.length > 0 && (
    <ul class="post-tags" aria-label="Tags">
      {tags.map(tag => (
        <li>
          <span class="post-tag">{getTagLabel(tag)}</span>
        </li>
      ))}
    </ul>
  )
}
